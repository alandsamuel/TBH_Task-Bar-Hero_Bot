search_region:
  x: 0
  y: 0
  width: 0
  height: 0
matching:
  threshold: 0.7
timeouts:
  loop:
    min: 1.2
    max: 1.8
  after_click:
    min: 0.5
    max: 1.0
  step_wait:
    min: 3.0
    max: 5.0
combine_flow:
  wait:
    min: 2.5
    max: 3.5
  template: assets/combine.png
  back_template: assets/back_arrow.png
periodic_stash_sort:
  interval:
    min: 3.0
    max: 5.0
  between_clicks:
    min: 0.2
    max: 0.6
  stash_template: assets/stash_all.png
  sort_template: assets/sort.png
  stash_enabled: true
  sort_enabled: true
randomization:
  click_offset_px:
    min: -2
    max: 2
chest_check:
  templates:
  - name: boss_chest
    template: assets/boss_chest_icon.png
  - name: chest
    template: assets/chest_icon.png
steps:
- name: open_chest
  enabled: true
- name: auto_fill
  enabled: true
  template: assets/auto_fill.png
- name: stash_all
  enabled: true
  template: assets/stash_all.png
- name: close_stash
  enabled: true
  template: assets/back_arrow.png
features:
  main_loop: true
  periodic_stash_sort: true
log_lvl: INFO
window_scale: '1'
